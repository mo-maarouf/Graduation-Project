# ──────────────────────────────────────────────────────────────────────────────
# Tourongo — Docker environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git (it is already in .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_USERNAME=tourongo_user
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_hex_secret

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
OAUTH2_ID=your_google_client_id.apps.googleusercontent.com
OAUTH2_SECRET=your_google_client_secret

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
BREVO_HOST=smtp-relay.brevo.com
BREVO_USERNAME=your_brevo_login_email
BREVO_PASSWORD=your_brevo_smtp_key
BREVO_MAIL=noreply@tourongo.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of your frontend (used in emails, OAuth redirect URI)
FRONTEND_URL=http://localhost:3000

# Public URL of backend (baked into the Next.js bundle for browser-side fetches)
NEXT_PUBLIC_API_URL=http://localhost:8081
